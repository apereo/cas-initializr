          </style>
        </head>
        <body>
          <main class="page">
            <section class="hero">
              <div class="eyebrow">Apereo CAS Overlay</div>
              <h1>Diff Report</h1>
              <p class="subtitle">
                Compared local overlay files against the Apereo CAS source archive for
                <code>${escapeHtml(resolvedTag)}</code>. Open individual colorized diffs,
                raw unified diff files, or copy a per-file editor command.
              </p>

              <div class="cards">
                <div class="card">
                  <div class="label">CAS tag</div>
                  <div class="value tag">${escapeHtml(resolvedTag)}</div>
                </div>
                <div class="card">
                  <div class="label">Changed files</div>
                  <div class="value changed">${changed.size()}</div>
                </div>
                <div class="card">
                  <div class="label">Unchanged files</div>
                  <div class="value unchanged">${unchanged.size()}</div>
                </div>
                <div class="card">
                  <div class="label">Unmatched files</div>
                  <div class="value unmatched">${unmatched.size()}</div>
                </div>
              </div>
            </section>

            <section class="section">
              <div class="section-header">
                <h2>Changed Files</h2>
                <span class="status status-changed">${changed.size()} changed</span>
              </div>
              <p class="note">
                Open the colorized browser diff, the raw <code>.diff</code>, or use the editor commands.
              </p>
              <table>
                <thead>
                  <tr>
                    <th>Status</th>
                    <th>Overlay file</th>
                    <th>Upstream match</th>
                    <th>Diff</th>
                    <th>Editor commands</th>
                  </tr>
                </thead>
                <tbody>
                  ${changedRows}
                </tbody>
              </table>
            </section>

            <section class="section">
              <div class="section-header">
                <h2>Unmatched Files</h2>
                <span class="status status-unmatched">${unmatched.size()} unmatched</span>
              </div>
              <table>
                <thead>
                  <tr>
                    <th>Status</th>
                    <th colspan="4">Overlay file</th>
                  </tr>
                </thead>
                <tbody>
                  ${unmatchedRows}
                </tbody>
              </table>
            </section>

            <section class="section">
              <div class="section-header">
                <h2>Open in Diff Tools</h2>
              </div>
              <div class="commands">
                <div class="command">
                  <strong>Browser: open colorized diffs folder</strong>
                  <code>${escapeHtml(vscodeOpenColorDiffsCommand)}</code>
                </div>

                <div class="command">
                  <strong>VS Code: open generated raw unified diffs</strong>
                  <code>${escapeHtml(vscodeOpenDiffsCommand)}</code>
                </div>

                <div class="command">
                  <strong>IntelliJ IDEA: directory diff</strong>
                  <code>${escapeHtml(ideaDirectoryDiffCommand)}</code>
                </div>

                <div class="command">
                  <strong>macOS FileMerge / opendiff: directory diff</strong>
                  <code>${escapeHtml(opendiffCommand)}</code>
                </div>

                <div class="command">
                  <strong>Meld: directory diff</strong>
                  <code>${escapeHtml(meldCommand)}</code>
                </div>
              </div>
            </section>

            <div class="footer">
              Generated by the Gradle <code>diff</code> task.
            </div>
          </main>
        </body>
        </html>
        """.stripIndent()
    }

    private static String renderColorizedDiffHtml(String overlayPath, String upstreamPath, String diffText) {
        String rows = diffText.readLines().collect { line ->
            String cssClass = diffLineClass(line)
            String escaped = escapeHtml(line)

            """
            <div class="line ${cssClass}">
              <span class="gutter">${escapeHtml(diffLinePrefix(line))}</span>
              <code>${escaped}</code>
            </div>
            """
        }.join(System.lineSeparator())

        return """
        <!doctype html>
        <html lang="en">
        <head>
          <meta charset="utf-8">
          <meta name="viewport" content="width=device-width, initial-scale=1">
          <title>Diff: ${escapeHtml(overlayPath)}</title>
          <style>
            :root {
              --bg: #0f172a;
              --panel: #111827;
              --text: #e5e7eb;
              --muted: #94a3b8;
              --border: rgba(148, 163, 184, 0.24);
              --add-bg: rgba(34, 197, 94, 0.16);
              --add-border: rgba(34, 197, 94, 0.38);
              --add-text: #bbf7d0;
              --del-bg: rgba(244, 63, 94, 0.16);
              --del-border: rgba(244, 63, 94, 0.38);
              --del-text: #fecdd3;
              --hunk-bg: rgba(56, 189, 248, 0.16);
              --hunk-border: rgba(56, 189, 248, 0.38);
              --hunk-text: #bae6fd;
              --meta-bg: rgba(168, 85, 247, 0.14);
              --meta-border: rgba(168, 85, 247, 0.35);
              --meta-text: #e9d5ff;
            }

            * {
              box-sizing: border-box;
            }

            body {
              margin: 0;
              color: var(--text);
              background:
                radial-gradient(circle at top left, rgba(56, 189, 248, 0.14), transparent 30rem),
                radial-gradient(circle at top right, rgba(168, 85, 247, 0.12), transparent 28rem),
                var(--bg);
              font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            }

            .page {
              width: min(1400px, calc(100% - 32px));
              margin: 0 auto;
              padding: 36px 0;
            }

            .header {
              border: 1px solid var(--border);
              background: rgba(17, 24, 39, 0.88);
              border-radius: 24px;
              padding: 24px;
              margin-bottom: 18px;
              box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
            }

            .eyebrow {
              color: #38bdf8;
              font-weight: 900;
              letter-spacing: 0.08em;
              text-transform: uppercase;
              font-size: 0.78rem;
            }

            h1 {
              margin: 8px 0 12px;
              font-size: clamp(1.5rem, 4vw, 3rem);
              line-height: 1.05;
              word-break: break-word;
            }

            .paths {
              display: grid;
              gap: 8px;
              color: var(--muted);
            }

            .paths code {
              color: #dbeafe;
              background: rgba(15, 23, 42, 0.9);
              border: 1px solid var(--border);
              border-radius: 10px;
              padding: 0.18rem 0.42rem;
              word-break: break-word;
            }

            .diff {
              border: 1px solid var(--border);
              background: rgba(17, 24, 39, 0.9);
              border-radius: 24px;
              overflow: hidden;
              box-shadow: 0 24px 80px rgba(0, 0, 0, 0.24);
            }

            .toolbar {
              position: sticky;
              top: 0;
              z-index: 2;
              display: flex;
              justify-content: space-between;
              gap: 12px;
              align-items: center;
              padding: 14px 18px;
              background: rgba(15, 23, 42, 0.96);
              border-bottom: 1px solid var(--border);
              backdrop-filter: blur(10px);
            }

            .legend {
              display: flex;
              gap: 10px;
              flex-wrap: wrap;
              color: var(--muted);
              font-size: 0.86rem;
            }

            .pill {
              border-radius: 999px;
              padding: 0.18rem 0.52rem;
              font-weight: 800;
            }

            .pill-add {
              color: #052e16;
              background: #86efac;
            }

            .pill-del {
              color: #450a0a;
              background: #fda4af;
            }

            .pill-hunk {
              color: #082f49;
              background: #7dd3fc;
            }

            .content {
              overflow-x: auto;
              font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
              font-size: 13px;
              line-height: 1.55;
            }

            .line {
              display: grid;
              grid-template-columns: 48px minmax(max-content, 1fr);
              border-left: 4px solid transparent;
              min-width: fit-content;
            }

            .line:hover {
              filter: brightness(1.08);
            }

            .gutter {
              user-select: none;
              color: var(--muted);
              text-align: center;
              padding: 0 10px;
              border-right: 1px solid rgba(148, 163, 184, 0.16);
              background: rgba(15, 23, 42, 0.55);
            }

            .line code {
              white-space: pre;
              padding: 0 14px;
              color: var(--text);
              background: transparent;
              border: 0;
            }

            .line-add {
              background: var(--add-bg);
              border-left-color: var(--add-border);
            }

            .line-add code {
              color: var(--add-text);
            }

            .line-delete {
              background: var(--del-bg);
              border-left-color: var(--del-border);
            }

            .line-delete code {
              color: var(--del-text);
            }

            .line-hunk {
              background: var(--hunk-bg);
              border-left-color: var(--hunk-border);
            }

            .line-hunk code {
              color: var(--hunk-text);
              font-weight: 800;
            }

            .line-meta {
              background: var(--meta-bg);
              border-left-color: var(--meta-border);
            }

            .line-meta code {
              color: var(--meta-text);
              font-weight: 700;
            }

            .line-context code {
              color: #cbd5e1;
            }

            .empty {
              color: var(--muted);
              padding: 24px;
            }
          </style>
        </head>
        <body>
          <main class="page">
            <section class="header">
              <div class="eyebrow">Colorized Unified Diff</div>
              <h1>${escapeHtml(overlayPath)}</h1>
              <div class="paths">
                <div>Upstream: <code>${escapeHtml(upstreamPath)}</code></div>
                <div>Overlay: <code>${escapeHtml(overlayPath)}</code></div>
              </div>
            </section>

            <section class="diff">
              <div class="toolbar">
                <strong>Diff</strong>
                <div class="legend">
                  <span class="pill pill-add">Added</span>
                  <span class="pill pill-del">Removed</span>
                  <span class="pill pill-hunk">Hunk</span>
                </div>
              </div>
              <div class="content">
                ${rows ?: '<div class="empty">No diff content.</div>'}
              </div>
            </section>
          </main>
        </body>
        </html>
        """.stripIndent()
    }

    private static String diffLineClass(String line) {
        if (line.startsWith("@@")) {
            return "line-hunk"
        }

        if (line.startsWith("diff ") ||
            line.startsWith("index ") ||
            line.startsWith("--- ") ||
            line.startsWith("+++ ")) {
            return "line-meta"
        }

        if (line.startsWith("+")) {
            return "line-add"
        }

        if (line.startsWith("-")) {
            return "line-delete"
        }

        return "line-context"
    }

    private static String diffLinePrefix(String line) {
        if (line.startsWith("@@")) {
            return "@@"
        }

        if (line.startsWith("+")) {
            return "+"
        }

        if (line.startsWith("-")) {
            return "-"
        }

        if (line.startsWith("diff ") ||
            line.startsWith("index ") ||
            line.startsWith("--- ") ||
            line.startsWith("+++ ")) {
            return "i"
        }

        return ""
    }

    private static String escapeHtml(String input) {
        if (input == null) {
            return ""
        }

        return input
            .replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;")
            .replace("\"", "&quot;")
            .replace("'", "&#39;")
    }

    private void logHeader(Object message) {
        logger.lifecycle("")
        logger.lifecycle("${MAGENTA}${BOLD}== ${String.valueOf(message)} ==${RESET}".toString())
    }

    private void logInfo(Object label, Object value) {
        logger.lifecycle("${BLUE}${BOLD}INFO${RESET} ${String.valueOf(label)}: ${CYAN}${String.valueOf(value)}${RESET}".toString())
    }

    private void logSuccess(Object label, Object value) {
        logger.lifecycle("${GREEN}${BOLD}OK${RESET} ${String.valueOf(label)}: ${GREEN}${String.valueOf(value)}${RESET}".toString())
    }

    private void logWarn(Object label, Object value) {
        logger.lifecycle("${YELLOW}${BOLD}WARN${RESET} ${String.valueOf(label)}: ${YELLOW}${String.valueOf(value)}${RESET}".toString())
    }

    private static String utf8(ByteArrayOutputStream output) {
      return new String(output.toByteArray(), StandardCharsets.UTF_8)
    }
}

